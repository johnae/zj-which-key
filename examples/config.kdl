// Zellij configuration for zj-which-key.
//
// The plugin is loaded once in the background as the "controller". It watches
// for mode changes and, after a short idle delay, spawns the floating popup.
// Run with:  zellij --config examples/config.kdl --layout examples/layout.kdl

load_plugins {
    "file:./target/wasm32-wasip1/release/zj_which_key.wasm" {
        // Show the popup automatically when you enter a non-base mode.
        auto_show "true"
        // Idle delay before the popup appears, in seconds.
        delay_secs "0.4"
        // Corner to dock the popup in: "bottom-right" or "bottom-left".
        position "bottom-right"
        // Cap the popup height at this percent of the screen; it pages beyond.
        max_height_pct "40"
    }
}

show_startup_tips false
show_release_notes false
